# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
# Options: sqlite, mysql
DB_DIALECT=sqlite

# SQLite Database (file path relative to backend folder)
DB_PATH=./data/restaurant.db

# MySQL Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=pos_restaurant
DB_USER=root
DB_PASSWORD=secret

# JWT Configuration
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7

# CORS Origins (comma separated)
CORS_ORIGIN=http://localhost:3000,http://localhost:3002,http://localhost:3003

# Payment Gateway (optional)
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# PAYMOB_HMAC_SECRET=your_paymob_hmac_secret
# Allow accepting webhooks without HMAC (ONLY for local development)
PAYMENT_ALLOW_INSECURE_WEBHOOKS=false

# Accounting Production Hardening
ACCOUNTING_STRICT_DEFAULTS=false
ACCOUNTING_AUTO_REMAP_POSTING=true
ACCOUNTING_ALLOW_GLOBAL_FALLBACK=true

# Coupons
# If true, coupon validation can fallback to any active branch-scoped coupon code
# when current branch mapping is inconsistent (useful in legacy duplicated-branch data).
COUPON_ALLOW_CROSS_BRANCH_FALLBACK=true

# Ops Monitoring & Backup
OPS_ALERTS_ENABLED=false
OPS_ALERT_WEBHOOK_URL=
OPS_ALERT_MIN_INTERVAL_SECONDS=60
OPS_ALERT_TIMEOUT_MS=8000
OPS_BACKUP_SCHEDULE_TIME=02:30
OPS_BACKUP_RETENTION_DAYS=14
# Optional: override MySQL CLI binaries location
# MYSQL_BIN_DIR=C:\Program Files\MySQL\MySQL Server 9.6\bin
